FROM node:22-alpine

WORKDIR /app

# Copy the Next.js source (the /web folder)
COPY web/ ./web/

# Install dependencies
WORKDIR /app/web
RUN npm install --silent

# Build the production bundle
RUN npm run build

# Expose the default Next.js port
EXPOSE 3000

# Run the Next.js server
CMD ["npm", "run", "start"]